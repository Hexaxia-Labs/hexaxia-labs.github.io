---
const today = new Date();
---

<footer class="border-t border-[#1E2028] mt-24">
  <div class="mx-auto max-w-3xl px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-xs text-[#6B7280] font-mono">
      &copy; {today.getFullYear()} Hexaxia Labs. Open source work from the <a href="https://www.hexaxia.tech" class="text-[#9CA3AF] hover:text-[#A3E635] transition-colors no-underline">Hexaxia group</a>.
    </p>
    <div class="flex items-center gap-5">
      <a href="https://www.hexaxia.tech" class="text-xs text-[#6B7280] hover:text-[#9CA3AF] transition-colors no-underline">.tech</a>
      <a href="https://www.hexaxia.ai" class="text-xs text-[#6B7280] hover:text-[#9CA3AF] transition-colors no-underline">.ai</a>
      <a href="https://hexaxia.media" class="text-xs text-[#6B7280] hover:text-[#9CA3AF] transition-colors no-underline">.media</a>
      <a href="https://github.com/Hexaxia-Labs" target="_blank" rel="noopener noreferrer" class="text-xs text-[#6B7280] hover:text-[#A3E635] transition-colors no-underline">GitHub</a>
    </div>
  </div>
</footer>
