---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16">
      <article>
        <header class="mb-12 pb-8 border-b border-[#1E2028]">
          <div class="mb-4 font-mono text-xs text-[#6B7280] tracking-widest uppercase">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="ml-3 text-[#4B5563]">Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1 class="text-2xl sm:text-3xl font-semibold text-[#E8E4D8] leading-snug tracking-tight">{title}</h1>
          {description && (
            <p class="mt-4 text-[#9CA3AF] text-base leading-relaxed">{description}</p>
          )}
        </header>
        <div class="prose">
          <slot />
        </div>
        <div class="mt-16 pt-8 border-t border-[#1E2028]">
          <a href="/blog" class="font-mono text-xs text-[#6B7280] hover:text-[#A3E635] transition-colors no-underline tracking-widest uppercase">Back to all posts</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
