---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, author } = Astro.props;

const pageUrl = Astro.url.href;
const datePublished = new Date(pubDate).toISOString();
const dateModified = updatedDate ? new Date(updatedDate).toISOString() : datePublished;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  url: pageUrl,
  datePublished,
  dateModified,
  inLanguage: 'en-US',
  author: {
    '@type': 'Person',
    name: 'Aaron Lamb',
    url: 'https://github.com/alamb-hex',
    sameAs: [
      'https://github.com/alamb-hex',
      'https://github.com/Hexaxia-Labs',
      'https://www.hexaxia.tech',
    ],
    jobTitle: 'Co-Founder, Hexaxia Technologies',
    worksFor: {
      '@type': 'Organization',
      name: 'Hexaxia Technologies',
      url: 'https://www.hexaxia.tech',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hexaxia Labs',
    url: 'https://labs.hexaxia.tech',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.hexaxia.tech/images/hexaxia_logo_3.webp',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.post-title', '.post-description'],
  },
};
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16">
      <article>
        <header class="mb-12 pb-8 border-b border-[#1E2028]">
          <div class="mb-4 font-mono text-xs text-[#6B7280] tracking-widest uppercase">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="ml-3 text-[#4B5563]">Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1 class="post-title text-2xl sm:text-3xl font-semibold text-[#E8E4D8] leading-snug tracking-tight">{title}</h1>
          {description && (
            <p class="post-description mt-4 text-[#9CA3AF] text-base leading-relaxed">{description}</p>
          )}
        </header>
        <div class="prose">
          <slot />
        </div>
        <div class="mt-16 pt-8 border-t border-[#1E2028]">
          <a href="/" class="font-mono text-xs text-[#6B7280] hover:text-[#A3E635] transition-colors no-underline tracking-widest uppercase">Back to all posts</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
