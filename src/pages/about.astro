---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="About | Hexaxia Labs" description="Hexaxia Labs is the open source arm of Hexaxia Technologies." />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16">
      <header class="mb-12 pb-8 border-b border-[#1E2028]">
        <p class="font-mono text-xs text-[#6B7280] tracking-widest uppercase mb-4">About</p>
        <h1 class="text-2xl sm:text-3xl font-semibold text-[#E8E4D8] tracking-tight">Hexaxia Labs</h1>
      </header>
      <div class="prose">
        <p>
          Hexaxia Labs is the open source arm of <a href="https://www.hexaxia.tech">Hexaxia Technologies</a>,
          an infrastructure and managed IT company based in Indianapolis.
        </p>
        <p>
          The projects here grow out of real work: hardening production systems, building compliance baselines,
          and shipping tooling that solves problems we actually have. When something is general enough to be
          useful outside our own infrastructure, we open source it.
        </p>
        <p>
          Projects live at <a href="https://github.com/Hexaxia-Labs">github.com/Hexaxia-Labs</a>.
        </p>
      </div>
    </main>
    <Footer />
  </body>
</html>
