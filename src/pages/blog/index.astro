---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16">
      <header class="mb-12 pb-8 border-b border-[#1E2028]">
        <p class="font-mono text-xs text-[#6B7280] tracking-widest uppercase mb-4">Blog</p>
        <h1 class="text-2xl sm:text-3xl font-semibold text-[#E8E4D8] tracking-tight">All posts</h1>
      </header>

      {posts.length === 0 ? (
        <p class="text-[#6B7280] font-mono text-sm">Posts coming soon.</p>
      ) : (
        <ul class="space-y-0">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="group flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-6 py-6 border-b border-[#1E2028] no-underline hover:border-[#A3E635] transition-colors">
                <div class="flex flex-col gap-2">
                  <span class="text-[#E8E4D8] group-hover:text-[#A3E635] transition-colors font-medium text-base leading-snug">
                    {post.data.title}
                  </span>
                  {post.data.description && (
                    <span class="text-sm text-[#6B7280] leading-relaxed line-clamp-2">{post.data.description}</span>
                  )}
                </div>
                <span class="font-mono text-xs text-[#6B7280] shrink-0 pt-0.5">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>
