---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-16">
      <header class="mb-12 pb-8 border-b border-[#1E2028]">
        <p class="font-mono text-xs text-[#6B7280] tracking-widest uppercase mb-4">Blog</p>
        <h1 class="text-2xl sm:text-3xl font-semibold text-[#E8E4D8] tracking-tight">All posts</h1>
      </header>

      {posts.length === 0 ? (
        <p class="text-[#6B7280] font-mono text-sm">Posts coming soon.</p>
      ) : (
        <ul class="space-y-0">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}/`}
                class="group block py-8 border-b border-[#1E2028] hover:border-[#A3E635] no-underline transition-colors"
              >
                <div class="flex items-start justify-between gap-6">
                  <div class="flex-1 min-w-0 space-y-3">
                    <h2 class="text-lg sm:text-xl font-semibold text-[#E8E4D8] group-hover:text-[#A3E635] transition-colors leading-snug">
                      {post.data.title}
                    </h2>
                    {post.data.description && (
                      <p class="text-sm text-[#9CA3AF] leading-relaxed">
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex items-center gap-4 pt-1">
                      {post.data.author && (
                        <span class="font-mono text-xs text-[#6B7280]">{post.data.author}</span>
                      )}
                      <span class="font-mono text-xs text-[#4B5563]">
                        <FormattedDate date={post.data.pubDate} />
                      </span>
                    </div>
                  </div>
                  <span class="shrink-0 mt-1 text-[#4B5563] group-hover:text-[#A3E635] transition-colors">
                    &rarr;
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>
